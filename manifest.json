{
    "manifest_version": 2,
    "name": "MT",
    "description": "Mention feature",
    "version": "0.1",
    "author": "Ahmed AlBattashi",
    "browser_specific_settings": {
        "gecko": {
            "id": "composescript@mv2.sample.extensions.thunderbird.net"
        }
    },
    "permissions": [
        "compose",
        "tabs",
        "cookies",
        "<all_urls>"
    ],
    "background": {
        "page": "background.html"
    },
    "browser_action": {
        "default_popup": "notify/notify.html",
        "default_title": "@",
        "default_icon": "images/mention.png"
    }
}